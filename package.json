{
  "name": "ur-agent",
  "version": "1.46.0",
  "description": "UR-Nexus — autonomous engineering workflow engine (plan, execute, test, verify, document, benchmark, reproduce)",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "engines": {
    "node": ">=18.18",
    "bun": ">=1.3.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Maitham16/UR.git"
  },
  "bugs": {
    "url": "https://github.com/Maitham16/UR/issues"
  },
  "homepage": "https://github.com/Maitham16/UR#readme",
  "license": "LicenseRef-UR-Nexus-Non-Commercial-Self-Responsibility",
  "keywords": [
    "agent",
    "cli",
    "coding-agent",
    "terminal",
    "ur"
  ],
  "bin": {
    "ur": "bin/ur.js"
  },
  "files": [
    "bin",
    "dist",
    "docs",
    "documentation",
    "extensions",
    "examples",
    "plugins",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "QUALITY.md",
    "README.md",
    "RELEASE.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node ./bin/ur.js",
    "dev": "bun --watch run src/entrypoints/cli.tsx",
    "bundle": "node scripts/bundle.mjs",
    "build": "node scripts/bundle.mjs",
    "release:check": "node scripts/release-check.mjs",
    "release:create-source-zip": "bun scripts/source-zip-create.mjs",
    "release:check-source-zip": "node scripts/source-zip-check.mjs",
    "typecheck": "bun run tsc --noEmit && bun run typecheck:strict-core",
    "typecheck:strict-core": "node scripts/strict-core-check.mjs",
    "lint": "node scripts/lint.mjs",
    "test": "bun test",
    "smoke": "node ./bin/ur.js --version",
    "secrets:scan": "bash scripts/secret-scan.sh",
    "dependencies:audit": "bun audit",
    "benchmark:report": "node scripts/benchmark-report.mjs",
    "benchmark:smoke": "node scripts/benchmark-smoke.mjs",
    "benchmark:local": "node scripts/benchmark-local.mjs",
    "benchmark:compare": "node scripts/benchmark-compare.mjs",
    "benchmark:swe-bench-lite": "node scripts/benchmark-external.mjs swe-bench-lite",
    "benchmark:terminal-bench": "node scripts/benchmark-external.mjs terminal-bench",
    "benchmark:aider-polyglot": "node scripts/benchmark-external.mjs aider-polyglot",
    "safety:matrix": "bun scripts/generate-safety-matrix.mjs",
    "provider:smoke": "bun scripts/provider-smoke.mjs",
    "package:check": "node scripts/package-check.mjs",
    "prepack": "bun run release:check"
  },
  "overrides": {
    "fast-uri": "3.1.3",
    "form-data": "4.0.6",
    "hono": "4.12.30",
    "ip-address": "10.2.0",
    "qs": "6.15.3"
  },
  "dependencies": {
    "@a2a-js/sdk": "0.3.14",
    "diff2html": "^3.4.56",
    "playwright-core": "^1.61.1",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@agentclientprotocol/sdk": "1.2.1",
    "@alcalzone/ansi-tokenize": "^0.1.3",
    "@aws-sdk/credential-provider-node": "^3.972.68",
    "@commander-js/extra-typings": "^13.1.0",
    "@growthbook/growthbook": "1.6.5",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/api-logs": "0.220.0",
    "@opentelemetry/core": "2.9.0",
    "@opentelemetry/resources": "2.9.0",
    "@opentelemetry/sdk-logs": "0.220.0",
    "@opentelemetry/sdk-metrics": "2.9.0",
    "@opentelemetry/sdk-trace-base": "2.9.0",
    "@opentelemetry/semantic-conventions": "1.43.0",
    "@smithy/node-http-handler": "^4.9.6",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.20.1",
    "@types/picomatch": "^3.0.2",
    "@types/proper-lockfile": "^4.1.4",
    "@types/react": "^18.3.31",
    "@types/react-reconciler": "^0.28.9",
    "@types/semver": "^7.7.1",
    "@types/shell-quote": "^1.7.5",
    "@types/stack-utils": "^2.0.3",
    "@types/ws": "^8.18.1",
    "ajv": "^8.20.0",
    "asciichart": "^1.5.25",
    "auto-bind": "^5.0.1",
    "axios": "^1.18.1",
    "bidi-js": "^1.0.3",
    "bun-types": "^1.3.14",
    "chalk": "^5.6.2",
    "chokidar": "^4.0.3",
    "cli-boxes": "^3.0.0",
    "code-excerpt": "^4.0.0",
    "color-diff-napi": "^0.0.1",
    "commander": "^13.1.0",
    "diff": "^8.0.4",
    "emoji-regex": "^10.6.0",
    "env-paths": "^3.0.0",
    "execa": "^9.6.1",
    "fflate": "^0.8.3",
    "figures": "^6.1.0",
    "fuse.js": "^7.5.0",
    "get-east-asian-width": "^1.6.0",
    "google-auth-library": "^10.9.0",
    "highlight.js": "^11.11.1",
    "https-proxy-agent": "^7.0.6",
    "ignore": "^6.0.2",
    "indent-string": "^5.0.0",
    "jsonc-parser": "^3.3.1",
    "lodash-es": "^4.18.1",
    "lru-cache": "^11.5.2",
    "marked": "^18.0.6",
    "p-map": "^7.0.5",
    "picomatch": "^4.0.5",
    "proper-lockfile": "^4.1.2",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-compiler-runtime": "^1.0.0",
    "react-reconciler": "^0.33.0",
    "semver": "^7.8.5",
    "shell-quote": "^1.10.0",
    "signal-exit": "^4.1.0",
    "stack-utils": "^2.0.6",
    "strip-ansi": "^7.2.0",
    "supports-hyperlinks": "^3.2.0",
    "tree-kill": "^1.2.2",
    "type-fest": "^4.41.0",
    "typescript": "^5.9.3",
    "undici": "^7.28.0",
    "usehooks-ts": "^3.1.1",
    "vscode-jsonrpc": "^8.2.1",
    "vscode-languageserver-protocol": "^3.18.2",
    "vscode-languageserver-types": "^3.18.0",
    "wrap-ansi": "^9.0.2",
    "ws": "^8.21.1",
    "xss": "^1.0.15",
    "yaml": "^2.9.0",
    "zod": "^3.25.76"
  }
}
